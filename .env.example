# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Politics and War API key (from https://politicsandwar.com/account)
PNW_API_KEY=your_pnw_api_key_here

# Discord Guild (server) ID where the bot operates
GUILD_ID=your_guild_id_here

# Role IDs (comma-separated if multiple, or a single ID)
# Role assigned after successful /register verification
VERIFIED_ROLE_ID=your_verified_role_id_here

# bar3 client role ID
BAR3_CLIENT_ROLE_ID=your_bar3_client_role_id_here

# bar3 server role ID
BAR3_SERVER_ROLE_ID=your_bar3_server_role_id_here

# Path to the SQLite database file (defaults to registrations.db)
DB_PATH=registrations.db